rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // USERS COLLECTION
    match /users/{userId} {

      // Only the logged-in user can access their document
      allow read, write: if request.auth != null
                         && request.auth.uid == userId;

      // EVERYTHING inside user document (subcollections)
      match /{document=**} {
        allow read, write: if request.auth != null
                           && request.auth.uid == userId;
      }
    }
  }
}